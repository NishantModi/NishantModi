                    ],
                    tech: ["Java", "Shell Scripting", "Jenkins", "HTML/CSS", "SQL"]
                }
            ]
        };

        // --- STATE MANAGEMENT ---
        let currentFilter = 'all';
        let selectedExpId = 1;

        // --- NAVIGATION LOGIC ---
        function navTo(viewId) {
            // Hide all sections
            ['overview', 'experience', 'skills', 'certs'].forEach(id => {
                document.getElementById(`view-${id}`).classList.add('hidden');
                const btn = document.getElementById(`nav-${id}`);
                if(btn) btn.classList.remove('active', 'text-teal-700', 'font-semibold');
            });

            // Show selected
            document.getElementById(`view-${viewId}`).classList.remove('hidden');
            
            // Update Nav State
            const activeBtn = document.getElementById(`nav-${viewId}`);
            if(activeBtn) {
                activeBtn.classList.add('active', 'text-teal-700', 'font-semibold');
            }
            
            // Close mobile menu if open
            document.getElementById('mobile-nav').classList.add('hidden');

            // Trigger chart resize if needed
            if (viewId === 'overview') renderCompetencyChart();
            if (viewId === 'skills') renderSkillsBarChart();
        }

        function toggleMobileNav() {
            const nav = document.getElementById('mobile-nav');
            nav.classList.toggle('hidden');
        }

        // --- EXPERIENCE LOGIC ---
        function renderTimeline() {
            const container = document.getElementById('timeline-list');
            container.innerHTML = '';

            const filtered = profileData.experience.filter(item => 
                currentFilter === 'all' || item.type.includes(currentFilter)
            );

            filtered.forEach(item => {
                const el = document.createElement('div');
                // Styling the card based on selection
                const isSelected = item.id === selectedExpId;
                const borderClass = isSelected ? 'border-teal-500 bg-teal-50 ring-1 ring-teal-500' : 'border-stone-200 bg-white hover:border-teal-300';
                
                el.className = `p-4 rounded-lg border shadow-sm cursor-pointer transition-all ${borderClass}`;
                el.onclick = () => selectExperience(item.id);
                
                el.innerHTML = `
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-xs font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded uppercase tracking-wide">${item.date}</span>
                    </div>
                    <h4 class="font-bold text-stone-800">${item.role}</h4>
                    <p class="text-sm text-stone-500">${item.company}</p>
                    <p class="text-xs text-stone-400 mt-1">📍 ${item.location}</p>
                `;
                container.appendChild(el);
            });
        }

        function filterExperience(type) {
            currentFilter = type;
            // Update buttons
            document.querySelectorAll('.exp-filter').forEach(btn => {
                if(btn.innerText.toLowerCase().includes(type) || (type === 'all' && btn.innerText === 'All Roles') || (type === 'leadership' && btn.innerText === 'Leadership') || (type === 'international' && btn.innerText.includes('Germany'))) {
                     // Simple logic to highlight active button - resetting all first
                     // (For simplicity in this vanilla JS, checking class matching roughly)
                }
            });
            
            // Reset active classes manually for clarity
            const buttons = document.querySelectorAll('.exp-filter');
            buttons.forEach(b => {
                b.classList.remove('bg-teal-700', 'text-white');
                b.classList.add('bg-white', 'text-stone-600');
            });
            
            // Find the clicked button (event target would be better, but we passed string)
            // Lets just re-render timeline with the filter applied.
            // Highlight logic:
            const typeMap = {'all':0, 'cloud':1, 'leadership':2, 'international':3};
            const activeBtn = buttons[typeMap[type]];
            if(activeBtn) {
                activeBtn.classList.remove('bg-white', 'text-stone-600');
                activeBtn.classList.add('bg-teal-700', 'text-white');
            }

            renderTimeline();
        }

        function selectExperience(id) {
            selectedExpId = id;
            renderTimeline(); // To update highlight
            
            const data = profileData.experience.find(e => e.id === id);
            if (!data) return;

            // Animate transition
            const card = document.getElementById('role-detail-card');
            card.style.opacity = '0.5';
            
            setTimeout(() => {
                document.getElementById('detail-role').innerText = data.role;
                document.getElementById('detail-company').innerText = data.company;
                document.getElementById('detail-date').innerText = data.date;
                
                const impactList = document.getElementById('detail-impact');
                impactList.innerHTML = data.achievements.map(a => `<li class="leading-relaxed">${a}</li>`).join('');

                const techContainer = document.getElementById('tech-stack-container');
                const techList = document.getElementById('detail-tech');
                if (data.tech && data.tech.length > 0) {
                    techContainer.classList.remove('hidden');
                    techList.innerHTML = data.tech.map(t => 
                        `<span class="px-2 py-1 bg-stone-100 text-stone-600 rounded text-xs font-medium border border-stone-200">${t}</span>`
                    ).join('');
                } else {
                    techContainer.classList.add('hidden');
                }
                
                card.style.opacity = '1';
            }, 150);
        }

        // --- CHARTS ---
        let competencyChartInstance = null;
        let skillsBarChartInstance = null;

        function renderCompetencyChart() {
            const ctx = document.getElementById('competencyChart').getContext('2d');
            
            if (competencyChartInstance) competencyChartInstance.destroy();

            competencyChartInstance = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['Cloud Architecture', 'DevOps/CI-CD', 'IaC (Terraform)', 'AI & Automation', 'Team Leadership', 'Legacy Migration'],
                    datasets: [{
                        label: 'Proficiency Level',
                        data: [9, 9, 9, 8, 8, 8], // 0-10 scale based on resume
                        backgroundColor: 'rgba(15, 118, 110, 0.2)', // Teal-700 low opacity
                        borderColor: 'rgba(15, 118, 110, 1)',
                        pointBackgroundColor: '#fff',
                        pointBorderColor: 'rgba(15, 118, 110, 1)',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: 'rgba(15, 118, 110, 1)'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            angleLines: { color: '#e5e7eb' },
                            grid: { color: '#e5e7eb' },
                            pointLabels: {
                                font: { size: 12, family: "'Segoe UI', sans-serif" },
                                color: '#44403c'
                            },
                            suggestedMin: 0,
                            suggestedMax: 10,
                            ticks: { display: false } // Hide numbers
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        function renderSkillsBarChart() {
            const ctx = document.getElementById('skillsBarChart').getContext('2d');
            
            if (skillsBarChartInstance) return; // Only render once

            skillsBarChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Azure', 'AWS', 'Terraform', 'Azure DevOps', 'PowerShell', 'Python', 'SQL'],
                    datasets: [{
                        label: 'Years Experience',
                        data: [9.5, 6, 5, 8, 8, 4, 10], // Estimated based on 13.5 yr total and specific mentions
                        backgroundColor: [
                            'rgba(15, 118, 110, 0.8)',
                            'rgba(249, 115, 22, 0.8)', // Orange for AWS
                            'rgba(168, 162, 158, 0.8)', 
                            'rgba(15, 118, 110, 0.8)',
                            'rgba(168, 162, 158, 0.8)',
                            'rgba(168, 162, 158, 0.8)',
                            'rgba(168, 162, 158, 0.8)'
                        ],
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y', // Horizontal bar
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#78716c' }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { font: { weight: '500' }, color: '#44403c' }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // --- INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', () => {
            navTo('overview');
            renderTimeline();
            selectExperience(1); // Default select most recent
        });

    </script>
</body>
</html>
